---
import Layout from '@/layouts/Layout.astro'
import { getPressKitAssets } from '@/utils/presskit'
import { siGithub, siInstagram, siTiktok, siX, siYoutube } from 'simple-icons'

import { SOCIAL_LINKS } from '@/consts'
import { BriefcaseBusinessIcon, ExternalLinkIcon, MailIcon } from 'lucide-react'

const pageTitle = 'Contact | Ravenwhisp Studio'
const pageDescription = 'Get in touch with Ravenwhisp Studio.'
const contactEmail = 'ravenwhispstudios@gmail.com'
const logoPackAssets = getPressKitAssets('logo-pack')
const keyartAssets = getPressKitAssets('key-art')
const screenshotsAssets = getPressKitAssets('screenshots')
const studioShotsAssets = getPressKitAssets('studio-shots')

const socialItems = [
  { label: 'GitHub', href: SOCIAL_LINKS.github, iconPath: siGithub.path },
  { label: 'LinkedIn', href: SOCIAL_LINKS.linkedin, icon: BriefcaseBusinessIcon },
  { label: 'Instagram', href: SOCIAL_LINKS.instagram, iconPath: siInstagram.path },
  { label: 'TikTok', href: SOCIAL_LINKS.tiktok, iconPath: siTiktok.path },
  { label: 'YouTube', href: SOCIAL_LINKS.youtube, iconPath: siYoutube.path },
  { label: 'X (Twitter)', href: SOCIAL_LINKS.twitter, iconPath: siX.path }
]

const pressKitItems = [
  {
    title: 'Logo Pack',
    image: logoPackAssets[0]?.src || '/images/placeholder.png',
    href: '/contact/press-kit/logo-pack',
    alt: 'Ravenwhisp logo pack preview'
  },
  {
    title: 'Key Art',
    image: keyartAssets[0]?.src || '/images/placeholder.png',
    alt: 'Key art placeholder'
  },
  {
    title: 'Screenshots',
    image: screenshotsAssets[0]?.src || '/images/placeholder.png',
    alt: 'Screenshots placeholder'
  },
  {
    title: 'Studio Shots',
    image: studioShotsAssets[0]?.src || '/images/placeholder.png',
    alt: 'Studio shots placeholder'
  }
]
---

<Layout title={pageTitle} description={pageDescription}>
  <section class='py-12 sm:py-16'>
    <div class='mx-auto max-w-7xl space-y-10 px-4 sm:px-6 lg:px-8'>
      <div class='grid gap-6 lg:grid-cols-2'>
        <article class='bg-card border-border rounded-xl border p-6'>
          <h2 class='text-foreground text-2xl font-semibold'>Email</h2>
          <p class='text-muted-foreground mt-2'>For general inquiries, partnerships, and support:</p>
          <a
            href={`mailto:${contactEmail}`}
            class='text-primary mt-4 inline-flex items-center gap-2 text-lg font-semibold hover:underline'
          >
            <MailIcon className='size-5' />
            {contactEmail}
          </a>
        </article>

        <article class='bg-card border-border rounded-xl border p-6'>
          <h2 class='text-foreground text-2xl font-semibold'>Social Media</h2>
          <p class='text-muted-foreground mt-2'>Follow Ravenwhisp Studio:</p>
          <div class='mt-5 grid grid-cols-1 gap-3 sm:grid-cols-2'>
            {
              socialItems.map(item => {
                const Icon = item.icon

                return (
                  <a
                    href={item.href}
                    target='_blank'
                    rel='noopener noreferrer'
                    class='border-border hover:bg-muted inline-flex items-center justify-between rounded-lg border px-4 py-3 transition-colors'
                  >
                    <span class='text-foreground inline-flex items-center gap-2 font-medium'>
                      {item.iconPath ? (
                        <svg viewBox='0 0 24 24' aria-hidden='true' class='size-4 fill-current'>
                          <path d={item.iconPath} />
                        </svg>
                      ) : (
                        Icon && <Icon className='size-4' />
                      )}
                      {item.label}
                    </span>
                    <ExternalLinkIcon className='text-muted-foreground size-4' />
                  </a>
                )
              })
            }
          </div>
        </article>
      </div>

      <article class='space-y-4'>
        <div>
          <h2 class='text-foreground text-2xl font-semibold'>Press Kit</h2>
          <p class='text-muted-foreground mt-2'>
            Logo pack assets are available now. More press kit materials will be added here for media and content
            creators.
          </p>
        </div>

        <div class='grid gap-4 sm:grid-cols-2 lg:grid-cols-4'>
          {
            pressKitItems.map(item => {
              const content = (
                <>
                  <img
                    src={item.image}
                    alt={item.alt}
                    class='h-44 w-full object-cover transition-transform duration-300 group-hover:scale-105'
                    loading='lazy'
                  />
                  <div class='flex items-center justify-between px-4 py-3'>
                    <span class='text-foreground font-medium'>{item.title}</span>
                    <ExternalLinkIcon className='text-muted-foreground size-4' />
                  </div>
                </>
              )

              return item.href ? (
                <a href={item.href} class='group bg-card border-border overflow-hidden rounded-xl border'>
                  {content}
                </a>
              ) : (
                <div class='bg-card border-border overflow-hidden rounded-xl border opacity-70'>{content}</div>
              )
            })
          }
        </div>
      </article>
    </div>
  </section>
</Layout>
