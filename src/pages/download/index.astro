---
import Layout from '@/layouts/Layout.astro'

const pageTitle = 'Download | Bound By Death'
const pageDescription = 'Download information and platform availability for Bound By Death.'
---

<Layout title={pageTitle} description={pageDescription}>
  <section class='py-16 sm:py-24'>
    <div class='mx-auto max-w-4xl space-y-6 px-4 sm:px-6 lg:px-8'>
      <h1 class='text-foreground text-4xl font-bold'>Download</h1>
      <p class='text-muted-foreground text-lg'>
        Bound By Death is currently in development. Download links and platform availability will be published here.
      </p>
      <p class='text-muted-foreground'>Follow Ravenwhisp Studio channels for release and playtest announcements.</p>
    </div>
  </section>
</Layout>
