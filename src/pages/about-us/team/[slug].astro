---
import Layout from '@/layouts/Layout.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const people = await getCollection('people')
  const team = people.filter(person => person.data.type === 'team')

  return team.map(person => ({
    params: { slug: person.id },
    props: { person }
  }))
}

const { person } = Astro.props
const { Content } = await render(person)

const pageTitle = `${person.data.name} | Team | Ravenwhisp Studio`
const pageDescription = person.data.bio
---

<Layout title={pageTitle} description={pageDescription}>
  <section class='py-16 sm:py-24'>
    <div class='mx-auto max-w-4xl space-y-6 px-4 sm:px-6 lg:px-8'>
      <a href='/about-us' class='text-muted-foreground flex text-sm hover:underline'>← Back to About Us</a>

      <div class='flex items-start gap-5'>
        <img src={person.data.avatarUrl} alt={person.data.name} class='size-20 rounded-full object-cover' />
        <div class='space-y-2'>
          <h1 class='text-foreground text-4xl font-bold'>{person.data.name}</h1>
          <p class='text-muted-foreground text-lg'>{person.data.bio}</p>
        </div>
      </div>

      <article class='prose dark:prose-invert max-w-none'>
        <Content />
      </article>
    </div>
  </section>
</Layout>
