---
import Layout from '@/layouts/Layout.astro'
import { getCollection } from 'astro:content'
import { sortPostsByPubDate } from '@/utils/blog'

import HeroSection from '@/components/blocks/hero-section/hero-section'
import HomeBlogPreview from '@/components/blocks/home-blog-preview/home-blog-preview'
import CTA from '@/components/blocks/cta-section/cta-section'

// Get all blog posts and convert to the format expected by components
const allPosts = await getCollection('blog')
const allPeople = await getCollection('people')
const publishedPosts = allPosts

const peopleById = new Map(allPeople.map(person => [person.id, person]))
const getAuthorId = (author: { id: string } | string) => (typeof author === 'string' ? author : author.id)

// Convert to the format expected by the React components
const allBlogPosts = publishedPosts.map((post, index) => {
  const authorId = getAuthorId(post.data.author)
  const authorPerson = peopleById.get(authorId)

  return {
    id: post.data.id || index + 1,
    slug: post.data.slug || post.id,
    title: post.data.title,
    description: post.data.description,
    imageUrl: post.data.imageUrl || '/images/blog-post/post-1.webp',
    imageAlt: post.data.imageAlt || post.data.title,
    pubDate: post.data.pubDate,
    category: post.data.category,
    author: authorPerson?.data.name || 'Unknown Author',
    avatarUrl: authorPerson?.data.avatarUrl || '/images/avatars/post-1.webp',
    authorUrl: authorPerson?.data.type === 'team' ? `/about-us/team/${authorId}` : undefined,
    readTime: post.data.readTime || 5,
    featured: post.data.featured || false
  }
})

const sortedBlogPosts = sortPostsByPubDate(allBlogPosts)
const featuredPosts = sortedBlogPosts.filter(post => post.featured).slice(0, 2)
const latestNonFeaturedPosts = sortedBlogPosts.filter(post => !post.featured).slice(0, 3)

// Page-specific SEO configuration
const pageTitle = 'Bound By Death | Ravenwhisp Studio'
const pageDescription =
  'Bound By Death is a dark fantasy co-op hack-and-slash from Ravenwhisp Studio. Explore the world, meet the team, and follow development updates.'
const pageKeywords =
  'Bound By Death, Ravenwhisp Studio, indie game, dark fantasy, co-op game, hack-and-slash, game development, devlog'

// Structured data for better SEO
const schema = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  name: 'Bound By Death',
  description: pageDescription,
  genre: ['Action', 'Hack and Slash', 'Co-op', 'Dark Fantasy'],
  author: {
    '@type': 'Organization',
    name: 'Ravenwhisp Studio'
  },
  publisher: {
    '@type': 'Organization',
    name: 'Ravenwhisp Studio'
  }
}
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords} schema={schema}>
  <!--  All Sections -->
  <HeroSection client:load />
  <HomeBlogPreview featuredPosts={featuredPosts} latestNonFeaturedPosts={latestNonFeaturedPosts} client:load />
</Layout>
